{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "nord",
  "diff_style": "auto",
  "mouse": false,
  "keybinds": {
    "editor_open": "ctrl+g",
    "messages_first": "none",
    "session_child_first": "<leader>j",
    "session_child_cycle": "l",
    "session_child_cycle_reverse": "h",
    "session_parent": "k",
    "permission_diff_up": "k",
    "permission_diff_down": "j"
  }
}
