# vim: set sw=2 sts=2 ts=2 noexpandtab :
[credential]
	helper = cache

[user]
	email = mateusz.hawrus@nobl9.com
	name = Mateusz Hawrus

[url "git@gitlab.com:"]
	insteadOf = https://gitlab.com/

[url "git@github.com:"]
	insteadOf = https://github.com/

[commit]
	template = ~/.dotfiles/config/git/commit-template

[pull]
  rebase = false

[merge]
	tool = "vimdiff"
	prompt = false

[mergetool]
	keepBackup = false

[mergetool "vimdiff"]
	cmd = nvim -c DiffviewOpen

[column]
	ui = auto

[branch]
	sort = -committerdate

[maintenance]
	auto = false
	strategy = incremental

[init]
	defaultBranch = main

[core]
	excludesfile = ~/.dotfiles/config/git/gitignore-global
	editor = nvim
  autocrlf = input
  pager = git-pager

[alias]
	pushf = push --force-with-lease
	subup = submodule update --init --recursive
  tree = log --graph --pretty=format:'%Cblue%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%ar) %C(cyan)<%an>%Creset' --abbrev-commit
	pc = !"f() { remote=\"${1:-origin}\"; git push -u \"$remote\" $(git rev-parse --abbrev-ref HEAD); }; f"
	staash = stash --all
	me = !gitme.bash
	stashlost = !recover-lost-stash.bash
	c = !llmcommit
	test = "!echo \"^$(pwd)$\""
	worktree-switch = "!f() { script_root=\"${DOTFILES:-$(git rev-parse --show-toplevel)}\"; \"$script_root/scripts/worktree-switch\" \"$@\"; }; f \"$@\""

[interactive]
  diffFilter = delta --color-only

[diff "sopsdiffer"]
  textconv = "sops -d"

[delta]
	syntax-theme = Nord
  whitespace-error-style = 22 reverse
	plus-style = syntax "#0f2f2d"
	plus-emph-style = syntax "#1f4d4a"
	plus-non-emph-style = syntax "#0f2f2d"
  minus-style = syntax "#351512"
	minus-emph-style = syntax "#5f1f17"
	minus-non-emph-style = syntax "#351512"

	commit-decoration-style = bold yellow box ul
  file-style = omit
  file-decoration-style = none
  hunk-header-decoration-style = cyan box ul

  line-numbers = true
	line-numbers-zero-style = "#4c566a"
  line-numbers-minus-style = red
	line-numbers-plus-style = green
  line-numbers-left-format = "{nm:>3} "
	line-numbers-right-format = " ┃{np:>3} "
	line-numbers-right-style = cyan bold dim

  features = side-by-side
