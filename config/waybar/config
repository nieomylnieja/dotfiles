{
    "layer": "top",
    "position": "top",
    "height": 24,

    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["hyprland/window"],
    "modules-right": ["tray", "cpu", "custom/memory", "battery", "pulseaudio", "clock"],

    "hyprland/workspaces": {
        "format": "{id}",
        "persistent-workspaces": {
            "1": [], "2": [], "3": [], "4": [], "5": [],
            "6": [], "7": [], "8": [], "9": []
        }
    },

    "hyprland/window": {
        "max-length": 50
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    "cpu": {
        "format": "CPU {usage}%"
    },

    "custom/memory": {
        "exec": "/run/current-system/sw/bin/bash /home/mh/.dotfiles/config/waybar/scripts/memory-info.sh",
        "return-type": "json",
        "interval": 5
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "σΑ²³ {capacity}%",
        "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "σΑùü muted",
        "format-icons": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"],
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },

    "clock": {
        "format": "{:%H:%M %Y-%m-%d}"
    }
}
