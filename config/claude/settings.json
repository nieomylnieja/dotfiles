{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --theme=nord --style=powerline",
    "padding": 0
  },
  "model": "claude-opus-4-6",
  "cleanupPeriodDays": 99999,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "aiguide": {
      "source": {
        "source": "github",
        "repo": "timescale/pg-aiguide"
      }
    },
    "my-plugins": {
      "source": {
        "source": "directory",
        "path": "/home/mh/.dotfiles/config/claude/my-plugins"
      }
    }
  },
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true,
    "pg@aiguide": true,
    "gopls-lsp@my-plugins": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-env-files.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-review-permission/hook.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Skill",
      "Search",
      "AskUserQuestion",
      "WebSearch",
      "Write(/tmp/**)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:githubusercontent.com)",
      "WebFetch(domain:schemastore.org)",
      "Bash($DOTFILES/config/agents/skills/*/scripts/*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git status*)",
      "Bash(git branch*)",
      "Bash(git fetch*)",
      "Bash(echo*)",
      "Bash(fd*)",
      "Bash(sed*)",
      "Bash(awk*)",
      "Bash(find*)",
      "Bash(ls*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(make*)",
      "Bash(head*)",
      "Bash(just*)",
      "Bash(go*)",
      "Bash(gh issue view*)",
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr list*)",
      "Bash(gh run view*)",
      "Bash(gh api repos*)",
      "Bash(gh repo list*)",
      "Bash(gh search*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl explain*)",
      "Bash(agent-browser*)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "mcp__Context7__*",
      "mcp__atlassian__get*",
      "mcp__deepwiki__*",
      "mcp__slack__slack_read*",
      "mcp__slack__slack_search*",
      "mcp__groundcover__query*",
      "mcp__groundcover__get*",
      "mcp__groundcover__gcql_query",
      "mcp__grafana__list*",
      "mcp__grafana__query*",
      "mcp__grafana__search*",
      "mcp__grafana__get*",
      "mcp__sequential-thinking__*"
    ],
    "deny": [
      "Read(*.env)"
    ],
    "defaultMode": "default"
  }
}
