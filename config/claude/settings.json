{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --theme=nord --style=powerline",
    "padding": 0
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "aiguide": {
      "source": {
        "source": "github",
        "repo": "timescale/pg-aiguide"
      }
    }
  },
  "enabledPlugins": {
    "pr-review-toolkit@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "pg@aiguide": true
  },
  "permissions": {
    "allow": [
      "Skill",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(fd:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(make:*)",
      "Bash(just:*)",
      "Bash(go:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh run view:*)",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl explain:*)",
      "mcp__Context7__*",
      "mcp__grafana__get_*",
      "mcp__atlassian__get*",
      "mcp__deepwiki__*"
    ],
    "deny": [
      "Read(*.env)"
    ],
    "defaultMode": "default"
  }
}
