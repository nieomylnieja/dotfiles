{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "statusLine": {
    "type": "command",
    "command": "npx -y @owloops/claude-powerline@latest --theme=nord --style=powerline",
    "padding": 0
  },
  "cleanupPeriodDays": 99999,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-code"
      }
    },
    "aiguide": {
      "source": {
        "source": "github",
        "repo": "timescale/pg-aiguide"
      }
    },
    "my-plugins": {
      "source": {
        "source": "directory",
        "path": "/home/mh/.dotfiles/config/claude/my-plugins"
      }
    }
  },
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true,
    "pg@aiguide": true,
    "gopls-lsp@my-plugins": true
  },
  "permissions": {
    "allow": [
      "Skill",
      "Search",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:githubusercontent.com)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git status*)",
      "Bash(git branch*)",
      "Bash(echo*)",
      "Bash(fd*)",
      "Bash(find*)",
      "Bash(ls*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(make*)",
      "Bash(just*)",
      "Bash(go*)",
      "Bash(gh issue view*)",
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr list*)",
      "Bash(gh run view*)",
      "Bash(gh api repos*)",
      "Bash(gh search*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl explain*)",
      "Bash(agent-browser*)",
      "Bash(* --version)",
      "Bash(* --help *)",
      "mcp__Context7__*",
      "mcp__grafana__get_*",
      "mcp__atlassian__get*",
      "mcp__deepwiki__*",
      "mcp__slack__slack_read*"
    ],
    "deny": [
      "Read(*.env)"
    ],
    "defaultMode": "default"
  }
}
