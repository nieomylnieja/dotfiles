#!/usr/bin/env bash

set -Eeuo pipefail

readonly LAPTOP_MONITOR="eDP-1"
readonly LAPTOP_MODE="2560x1600@120"
readonly LAPTOP_SCALE="1.6"
readonly WATCH_INTERVAL_SECONDS="${HYPR_MONITOR_POLICY_INTERVAL_SECONDS:-2}"
readonly HYPRCTL="${HYPR_MONITOR_POLICY_HYPRCTL:-hyprctl}"
readonly JQ="${HYPR_MONITOR_POLICY_JQ:-jq}"

usage() {
	cat <<EOF
Usage: ${0##*/} [OPTION]
Apply the fail-safe Hyprland monitor policy.

Options:
  --once    reconcile monitor state once
  --watch   reconcile monitor state continuously (default)
  -h, --help
            display this help and exit

Policy:
  - with an external DP-* or HDMI-* monitor, enable that monitor and disable eDP-1
  - without an external monitor, enable eDP-1
  - on any failure, enable eDP-1 as the fallback and do not disable anything
EOF
}

log() {
	printf '%s\n' "$*" >&2
}

run_hyprctl() {
	local output status

	if output="$("${HYPRCTL}" "$@" 2>&1)"; then
		[[ -n "${output}" ]] && printf '%s\n' "${output}"
		return 0
	else
		status=$?
	fi

	if ((status != 0)); then
		log "hyprctl failed with exit ${status}: ${HYPRCTL} $*"
		[[ -n "${output}" ]] && log "${output}"
		return "${status}"
	fi
}

fallback_laptop() {
	local reason="${1:-unknown failure}"
	local output status

	log "Falling back to laptop monitor: ${reason}"
	if output="$("${HYPRCTL}" keyword monitor "${LAPTOP_MONITOR},${LAPTOP_MODE},0x0,${LAPTOP_SCALE}" 2>&1)"; then
		[[ -n "${output}" ]] && log "${output}"
		return 0
	else
		status=$?
	fi

	if ((status != 0)); then
		log "laptop fallback failed with exit ${status}: ${HYPRCTL} keyword monitor ${LAPTOP_MONITOR},${LAPTOP_MODE},0x0,${LAPTOP_SCALE}"
		[[ -n "${output}" ]] && log "${output}"
		return "${status}"
	fi
}

unexpected_error() {
	local status="$1"
	local line="$2"

	trap - ERR
	fallback_laptop "unexpected error at line ${line} (exit ${status})" || true
	exit "${status}"
}

trap 'unexpected_error "$?" "$LINENO"' ERR

monitor_json() {
	local output status

	if output="$("${HYPRCTL}" monitors all -j 2>&1)"; then
		:
	else
		status=$?
		log "hyprctl monitor query failed with exit ${status}: ${HYPRCTL} monitors all -j"
		[[ -n "${output}" ]] && log "${output}"
		return "${status}"
	fi

	if [[ -z "${output}" ]]; then
		log "hyprctl monitor query returned empty output"
		return 1
	fi

	printf '%s\n' "${output}"
}

external_monitor_name() {
	local json="$1"
	local output status

	if output="$("${JQ}" -r '
		if type != "array" then
			error("expected monitor array")
		else
			[
				.[]
				| select(.name != "eDP-1")
				| select(.name | test("^(DP|HDMI)-"))
				| .name
			]
			| sort
			| first // empty
		end
	' <<<"${json}" 2>&1)"; then
		:
	else
		status=$?
		log "jq failed with exit ${status} while parsing monitor JSON"
		[[ -n "${output}" ]] && log "${output}"
		return "${status}"
	fi

	printf '%s\n' "${output}"
}

reconcile() {
	local json external
	local status

	if json="$(monitor_json)"; then
		:
	else
		status=$?
		return "${status}"
	fi

	if external="$(external_monitor_name "${json}")"; then
		:
	else
		status=$?
		return "${status}"
	fi

	if [[ -n "${external}" ]]; then
		run_hyprctl keyword monitor "${external},preferred,0x0,1" >/dev/null || return
		run_hyprctl keyword monitor "${LAPTOP_MONITOR},disable" >/dev/null || return
		return
	fi

	run_hyprctl keyword monitor "${LAPTOP_MONITOR},${LAPTOP_MODE},0x0,${LAPTOP_SCALE}" >/dev/null || return
}

run_once() {
	local status

	if reconcile; then
		return 0
	else
		status=$?
	fi

	fallback_laptop "reconciliation failed with exit ${status}" || true
	return "${status}"
}

watch() {
	while true; do
		run_once || true
		sleep "${WATCH_INTERVAL_SECONDS}"
	done
}

main() {
	local mode="--watch"
	local status

	while (($# > 0)); do
		case "$1" in
		--once | --watch)
			mode="$1"
			shift
			;;
		-h | --help)
			usage
			exit 0
			;;
		*)
			log "Unknown option: $1"
			usage
			exit 2
			;;
		esac
	done

	case "${mode}" in
	--once)
		if run_once; then
			exit 0
		else
			status=$?
			exit "${status}"
		fi
		;;
	--watch)
		watch
		;;
	*)
		log "Unknown mode: ${mode}"
		exit 2
		;;
	esac
}

main "$@"
